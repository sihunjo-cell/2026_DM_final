# Crawler Database Config
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=soop_dm
DB_USER=soop_user
DB_PASSWORD=YOUR_PASSWORD_HERE

# CHZZK Open API Credentials (cần để check live status 1 cách chính thống)
# Lấy từ https://chzzk.naver.com/creator/api
CHZZK_CLIENT_ID=YOUR_CHZZK_CLIENT_ID
CHZZK_CLIENT_SECRET=YOUR_CHZZK_CLIENT_SECRET

# Application specific
SNAPSHOT_INTERVAL_SECONDS=60
CHAT_FLUSH_INTERVAL_SECONDS=3
CHAT_FLUSH_BATCH_SIZE=200
LOG_LEVEL=INFO
